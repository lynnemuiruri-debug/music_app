import pygame
class BoombaFM:
    def __init__(self):
        # These three store info about whichever song is currently selected,
        pygame.mixer.init()
        self.current_song_title = None
        self.current_song_file = None
        self.is_playing = False

    def select_song(self, title, file_path):
        """
        Just remembers which song the user picked — doesn't play it yet.
        """
        self.current_song_title = title
        self.current_song_file = file_path
        print(f"Selected Song: {title}")

    def play_current(self):
        """
        Loads the selected song's file and plays it.
        """
        if not self.current_song_file:
            print("No Song Selected. Please select a song first.")
            return

        try:
            pygame.mixer.music.load(self.current_song_file)
            pygame.mixer.music.play()
            self.is_playing = True
            print(f"Now Playing: {self.current_song_title}")
        except pygame.error as e:
            print(f"Cannot play song: {e}")

    def pause_song(self):
        """
        if self.is_playing:
            pygame.mixer.music.pause()
            self.is_playing = False
            print("Music Paused.")
        else:
            pygame.mixer.music.unpause()
            self.is_playing = True
            print("Music Resumed.")

    def stop_song(self):
        """
        Stops playback completely (can't resume from this point).
        """
        pygame.mixer.music.stop()
        self.is_playing = False
        print("Music Stopped.")
